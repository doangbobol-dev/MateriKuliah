.mk-hero-content {
    position: relative;
    z-index: 2;
    display: flex;
    flex-direction: column;
    align-items: center;
}

.mk-badge {
    background: white;
    color: #2563EB;
    padding: 10px 28px;
    border-radius: 50px;
    font-size: 15px;
    font-weight: 700;
    display: inline-flex;
    align-items: center;
    gap: 8px;
    margin-bottom: 24px;
    box-shadow: 0 4px 15px rgba(0,0,0,0.1);
}

.mk-hero h1 {
    font-size: 48px;
    margin-bottom: 16px;
    font-weight: 800;
    letter-spacing: -0.5px;
}

.mk-hero p {
    font-size: 18px;
    color: #DBEAFE; /* Biru muda pucat */
    max-width: 680px;
    margin: 0 auto;
    line-height: 1.6;
}

/* Penyesuaian agar grid card naik menimpa header */
.modern-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
    gap: 24px;
    margin-top: -60px; /* Menarik card ke atas menimpa hero */
    padding-bottom: 80px;
    position: relative;
    z-index: 10;
}


/* ==========================================================================
   HALAMAN TENTANG (SESUAI REFERENSI GAMBAR)
   ========================================================================== */
.tentang-hero {
    background: linear-gradient(135deg, #2563EB, #1E40AF);
    color: white;
    text-align: center;
    padding: 80px 20px 140px 20px; /* Padding bawah ekstra untuk efek floating */
}

.tentang-badge {
    background: white;
    color: #2563EB;
    padding: 6px 20px;
    border-radius: 50px;
    font-size: 13px;
    font-weight: 600;
    display: inline-flex;
    align-items: center;
    gap: 8px;
    margin-bottom: 24px;
}

.tentang-hero h1 {
    font-size: 40px;
    font-weight: 700;
    margin-bottom: 16px;
}

.tentang-hero p {
    font-size: 16px;
    opacity: 0.9;
    max-width: 600px;
    margin: 0 auto;
    line-height: 1.6;
}

/* Floating Info Bar */
.floating-info-bar {
    background: white;
    border-radius: 16px;
    box-shadow: 0 10px 30px rgba(0,0,0,0.08);
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    max-width: 900px;
    margin: -60px auto 80px; /* Menarik card ke atas menimpa banner */
    position: relative;
    z-index: 10;
    padding: 30px 20px;
    text-align: center;
}

.fib-item {
    border-right: 1px solid #E2E8F0;
    padding: 0 20px;
}
.fib-item:last-child {
    border-right: none;
}

.fib-icon {
    margin-bottom: 12px;
}
.fib-item h4 {
    font-size: 16px;
    color: var(--text-main);
    margin-bottom: 4px;
}
.fib-item p {
    font-size: 13px;
    color: var(--text-muted);
}

/* Split Section (Image + Text) */
.about-split {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 60px;
    align-items: center;
    margin-bottom: 100px;
}

.about-img-box {
    position: relative;
    border-radius: 16px;
    overflow: hidden;
    box-shadow: var(--shadow-hover);
}

/* Efek titik-titik (dot pattern) di belakang gambar */
.about-img-wrap {
    position: relative;
    padding-top: 20px;
    padding-left: 20px;
}
.about-img-wrap::before {
    content: '';
    position: absolute;
    top: 0; left: 0;
    width: 100px; height: 100px;
    background-image: radial-gradient(#94A3B8 20%, transparent 20%);
    background-size: 10px 10px;
    z-index: -1;
}

.about-img-box img {
    width: 100%;
    display: block;
    border-radius: 16px;
}

.about-text h2 {
    font-size: 28px;
    line-height: 1.3;
    margin-bottom: 20px;
    color: var(--text-main);
}
.about-text > p {
    color: var(--text-muted);
    line-height: 1.7;
    margin-bottom: 30px;
    font-size: 15px;
}

.about-list-item {
    display: flex;
    gap: 16px;
    margin-bottom: 24px;
    align-items: flex-start;
}
.ali-icon {
    width: 48px;
    height: 48px;
    border-radius: 12px;
    display: flex;
    justify-content: center;
    align-items: center;
    flex-shrink: 0;
}
.ali-icon.blue { background: #DBEAFE; color: #2563EB; }
.ali-icon.green { background: #D1FAE5; color: #059669; }

.ali-text h4 { font-size: 16px; margin-bottom: 4px; color: var(--text-main); }
.ali-text p { font-size: 13px; color: var(--text-muted); line-height: 1.5; }

/* Team Section */
.team-section {
    background: #F8FAFC;
    padding: 80px 0;
    border-top: 1px solid #E2E8F0;
}

.team-header {
    text-align: center;
    margin-bottom: 50px;
}
.team-header h2 {
    font-size: 32px;
    margin-bottom: 12px;
}
.team-header p {
    color: var(--text-muted);
    max-width: 600px;
    margin: 0 auto;
    font-size: 15px;
}

.team-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
    gap: 24px;
}

.team-card {
    background: white;
    border-radius: 16px;
    padding: 30px 20px;
    text-align: center;
    box-shadow: var(--shadow-soft);
    transition: var(--transition);
}
.team-card:hover {
    transform: translateY(-5px);
    box-shadow: var(--shadow-hover);
}

.team-avatar {
    width: 80px;
    height: 80px;
    border-radius: 50%;
    margin: 0 auto 16px;
    object-fit: cover;
    border: 3px solid #E2E8F0;
}

.team-card h3 {
    font-size: 16px;
    margin-bottom: 8px;
}

.team-role-badge {
    display: inline-block;
    padding: 4px 12px;
    border-radius: 50px;
    font-size: 11px;
    font-weight: 600;
    color: white;
    margin-bottom: 16px;
}
.team-role-badge.blue { background: #2563EB; }
.team-role-badge.green { background: #059669; }
.team-role-badge.orange { background: #D97706; }
.team-role-badge.red { background: #DC2626; }

.team-card p {
    font-size: 12px;
    color: var(--text-muted);
    line-height: 1.6;
}

@media (max-width: 900px) {
    .floating-info-bar { grid-template-columns: 1fr; gap: 20px; padding: 20px; }
    .fib-item { border-right: none; border-bottom: 1px solid #E2E8F0; padding-bottom: 20px; }
    .fib-item:last-child { border-bottom: none; padding-bottom: 0; }
    .about-split { grid-template-columns: 1fr; gap: 40px; }
}

document.addEventListener('DOMContentLoaded', () => {
    // Inisialisasi Lucide Icons
    lucide.createIcons();

    // Intersection Observer untuk Animasi Fade-in
    const observerOptions = {
        root: null,
        rootMargin: '0px',
        threshold: 0.1
    };

    const observer = new IntersectionObserver((entries, observer) => {
        entries.forEach(entry => {
            if (entry.isIntersecting) {
                entry.target.classList.add('fade-in');
                entry.target.style.opacity = "1";
                entry.target.style.transform = "translateY(0)";
                observer.unobserve(entry.target);
            }
        });
    }, observerOptions);

    const animatedElements = document.querySelectorAll('.card, .hero-content, table');
    animatedElements.forEach(el => {
        el.style.opacity = "0";
        el.style.transform = "translateY(20px)";
        el.style.transition = "all 0.8s ease-out";
        observer.observe(el);
    });

    // Fitur Search pada halaman materi.html
    const searchInput = document.getElementById('searchInput');
    if (searchInput) {
        searchInput.addEventListener('keyup', function(e) {
            const term = e.target.value.toLowerCase();
            const cards = document.querySelectorAll('.course-card');
            
            cards.forEach(card => {
                const title = card.querySelector('h3').textContent.toLowerCase();
                if (title.includes(term)) {
                    card.style.display = 'block';
                } else {
                    card.style.display = 'none';
                }
            });
        });
    }
});
